---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { planetData } from '../../data/planets';
import logoImage from '../../assets/ui/logoMiniPlanetas.png';
import likeButtonImage from '../../assets/ui/megusta.png';

type Planet = {
	imageShareFileName?: string;
	imageFull?: string;
	slug: string;
	name: string;
	image: string;
	image360?: string;
	description: string;
	nombreCientifico: string;
	location: string;
	coordinates: string;
	discoveryDate: string;
	equipment: string;
};

export function getStaticPaths() {
	return planetData.map((planet) => ({
		params: { slug: planet.slug },
		props: { planet },
	}));
}

const { planet } = Astro.props as {
	planet: Planet;
};
const basePath = import.meta.env.BASE_URL;
const normalizedBase =
	basePath === '/' ? '' : `/${basePath.replace(/^\/+|\/+$/g, '')}`;
const toBasePath = (path = '') => `${normalizedBase}/${path.replace(/^\/+/, '')}`;
const toAssetPath = (path = '') => {
	if (path.includes('/assets/planets/')) {
		return `${normalizedBase}/src${path}`;
	}
	return path.startsWith('/') ? `${normalizedBase}${path}` : `${normalizedBase}/${path}`;
};
const toPublicAssetPath = (path = '') =>
	typeof path === 'string' && normalizedBase && path.startsWith(`${normalizedBase}/`)
		? path.slice(normalizedBase.length)
		: path;
const planetImages = import.meta.glob('../../assets/planets/*.{jpg,jpeg,png,JPG,JPEG,PNG}', {
	eager: true,
	import: 'default',
});
const planetImageFileName = planet.image.split('/').pop() ?? '';
const optimizedPlanetImage = Object.entries(planetImages).find(([filePath]) =>
	filePath.endsWith(`/${planetImageFileName}`)
)?.[1] as ImageMetadata | undefined;
const viewerImagePath = planet.imageFull
	? toAssetPath(planet.imageFull)
	: optimizedPlanetImage?.src ?? toAssetPath(planet.image);
const discoveryDate = new Date(planet.discoveryDate).toLocaleDateString('es-ES', {
	day: '2-digit',
	month: 'long',
	year: 'numeric',
});
const sphericalImage = planet.image360;
const sphericalPublicPath = sphericalImage ? toPublicAssetPath(sphericalImage) : null;
// Comprobación robusta de existencia de imagen 360 usando import.meta.glob
const pano360Images = import.meta.glob('../../assets/pano360/*.{jpg,jpeg,png,JPG,JPEG,PNG}', {eager: true});
const pano360FileName = typeof planet.image360 === 'string' ? planet.image360.split('/').pop() : '';
const hasEquirectangularImage = Boolean(
	sphericalPublicPath?.startsWith('/pano360/') &&
	pano360FileName &&
	Object.keys(pano360Images).some(filePath => filePath.endsWith(`/${pano360FileName}`))
);
const fullScreenIcon = toBasePath('FullScreen.png');
const landingIcon = toBasePath('Landing.png');
const shareIcon = toBasePath('compartir.png');
const siteUrl = Astro.site ?? new URL('https://albertoepic.github.io');
const planetRelativeUrl = toBasePath(`planetas/${planet.slug}/`);
const planetAbsoluteUrl = new URL(planetRelativeUrl, siteUrl).toString();
// Fuerza extensión JPG para redes sociales
const shareImageFileName = planet.image.split('/').pop()?.replace(/\.(webp|png|jpeg)$/i, '.jpg') ?? '';
const shareImagePath = `/planets-share/${shareImageFileName}`;
const shareImageUrl = shareImagePath; // Para uso en el DOM (relativo)
const shareImageAbsoluteUrl = new URL(shareImagePath, siteUrl).toString();
const shareDescription =
	planet.description.length > 200
		? `${planet.description.slice(0, 197)}...`
		: planet.description;
const likesApiUrl = import.meta.env.PUBLIC_PLANET_LIKES_API_URL?.trim() ?? '';
const planetIndex = planetData.findIndex(p => p.slug === planet.slug);
const prevPlanet = planetData[planetIndex - 1] ?? planetData[planetData.length - 1];
const nextPlanet = planetData[planetIndex + 1] ?? planetData[0];
const leftArrowSVG = `<svg width='32' height='32' viewBox='0 0 24 24'><path d='M15 18l-6-6 6-6' stroke='currentColor' stroke-width='2' fill='none'/></svg>`;
const rightArrowSVG = `<svg width='32' height='32' viewBox='0 0 24 24'><path d='M9 6l6 6-6 6' stroke='currentColor' stroke-width='2' fill='none'/></svg>`;
const prevUrl = toBasePath(`planetas/${prevPlanet.slug}/`);
const nextUrl = toBasePath(`planetas/${nextPlanet.slug}/`);
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href={toBasePath('faviconMP.png')} />
		<link rel="shortcut icon" type="image/png" href={toBasePath('faviconMP.png')} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{planet.name} | MINIPLANETAS</title>
		<meta name="description" content={shareDescription} />
		<link rel="canonical" href={planetAbsoluteUrl} />

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="MINIPLANETAS" />
		<meta property="og:title" content={`${planet.name} | MINIPLANETAS`} />
		<meta property="og:description" content={shareDescription} />
		<meta property="og:url" content={planetAbsoluteUrl} />
		<meta property="og:image" content={`https://raw.githubusercontent.com/AlbertoEpic/MINIPLANETAS/refs/heads/gh-pages/planets-share/${encodeURIComponent(planet.imageShareFileName ? planet.imageShareFileName : (planet.image ? planet.image.split('/').pop() ?? `${planet.name.replace(/\s+/g, '_')}.jpg` : `${planet.name.replace(/\s+/g, '_')}.jpg`))}`} />
		<meta property="og:image:type" content="image/jpeg" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="1200" />
		<meta property="og:image:alt" content={`Mini-planeta ${planet.name}`} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={`${planet.name} | MINIPLANETAS`} />
		<meta name="twitter:description" content={shareDescription} />
		<meta name="twitter:image" content={shareImageAbsoluteUrl} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Space+Grotesk:wght@400;500;600&display=swap"
		/>
		<link rel="stylesheet" href="/styles/arrows.css" />
	</head>
	<body>
		<header class="top">
			<a class="brand" href={toBasePath('')}>
				<Image src={logoImage} alt="" class="brand-logo" aria-hidden="true" loading="eager" />
				<span class="brand-text">MINIPLANETAS</span>
			</a>
			<button class="menu-toggle" type="button" aria-label="Abrir menú" aria-controls="main-nav" aria-expanded="false">
				<span></span>
				<span></span>
				<span></span>
			</button>
			<nav class="top-nav" id="main-nav">
				<a href={toBasePath('')}>El Universo</a>
				<a href={toBasePath('catalogo')} aria-current="page">Catálogo</a>
				<a href={toBasePath('como-nace-un-mini-planeta')}>¿Cómo nace un mini-planeta?</a>
				<a href={toBasePath('sobre-el-creador')}>Sobre el creador</a>
			</nav>
		</header>

		<main class="planet-view" data-prev-url={prevUrl} data-next-url={nextUrl} data-likes-api-url={likesApiUrl} data-planet-slug={planet.slug}>
			<a class="arrow arrow-left planet-arrows" href={toBasePath(`planetas/${prevPlanet.slug}/`)} title="Anterior">
				<img src="/ui/anterior.png" alt="Anterior" class="arrow-img" />
			</a>
			<a class="arrow arrow-right planet-arrows" href={toBasePath(`planetas/${nextPlanet.slug}/`)} title="Siguiente">
				<img src="/ui/siguiente.png" alt="Siguiente" class="arrow-img" />
			</a>
					<style>
					@media (max-width: 768px) {
						.planet-arrows {
							display: none !important;
						}
					}
					</style>
					<script is:inline>
					// Swipe navigation for mobile
					(function() {
						let touchStartX = 0;
						let touchStartY = 0;
						let touchEndX = 0;
						let touchEndY = 0;
						const horizontalThreshold = 90; // px
						const maxVerticalDrift = 70; // px
						const horizontalDominanceRatio = 1.5;
						const main = document.querySelector('.planet-view');
						// Leer las URLs desde los atributos data del main
						const prevUrl = main?.getAttribute('data-prev-url');
						const nextUrl = main?.getAttribute('data-next-url');
						if (!main) return;
						main.addEventListener('touchstart', function(e) {
							if (e.touches.length === 1) {
								touchStartX = e.touches[0].clientX;
								touchStartY = e.touches[0].clientY;
							}
						});
						main.addEventListener('touchend', function(e) {
							if (e.changedTouches.length === 1) {
								touchEndX = e.changedTouches[0].clientX;
								touchEndY = e.changedTouches[0].clientY;
								const diffX = touchEndX - touchStartX;
								const diffY = touchEndY - touchStartY;
								const absDiffX = Math.abs(diffX);
								const absDiffY = Math.abs(diffY);
								const isIntentionalHorizontalSwipe = absDiffX > horizontalThreshold
									&& absDiffY < maxVerticalDrift
									&& absDiffX > absDiffY * horizontalDominanceRatio;

								if (isIntentionalHorizontalSwipe) {
									if (diffX < 0 && nextUrl) {
										// Swipe izquierda (dedo va de derecha a izquierda): siguiente planeta
										window.location.href = nextUrl;
									} else if (diffX > 0 && prevUrl) {
										// Swipe derecha (dedo va de izquierda a derecha): planeta anterior
										window.location.href = prevUrl;
									}
								}
							}
						});
					})();
					</script>
			<section class="visual">
				{optimizedPlanetImage ? (
					   <Image src={optimizedPlanetImage} alt={`Vista grande de ${planet.name}`} loading="eager" width={optimizedPlanetImage.width} height={optimizedPlanetImage.height} data-main-image data-share-src={shareImageUrl} />
				) : (
					<span style={{color:'red'}}>Imagen no encontrada</span>
				)}
			</section>

			<section class="story">
				<p class="eyebrow">Ficha del Planeta</p>
				<div class="title-row">
					<div class="title-main">
						<h1>{planet.name}</h1>
						<p class="title-likes-meta" data-like-count-wrap aria-live="polite">
							<span class="title-likes-heart" aria-hidden="true">❤</span>
							<span class="title-like-count" data-like-count>A nadie le gusta ☹️</span>
						</p>
					</div>
					<button
						type="button"
						class="title-like-button"
						data-like-planet
						aria-pressed="false"
						aria-label="Marcar este planeta con Me gusta"
						title="Me gusta"
					>
						<Image src={likeButtonImage} alt="" class="title-like-icon" aria-hidden="true" loading="eager" />
						<span class="title-like-label" data-like-label aria-hidden="false">Me gusta</span>
					</button>
				</div>
				   <div class="lead-wrap">
					   <p class="lead is-collapsed" data-description id="planet-description-text"
						   set:html={planet.description.replace(/\n\n/g, '<br><br>')}
					   ></p>
					   <button type="button" class="lead-toggle" data-toggle-description aria-controls="planet-description-text" aria-expanded="false">Leer más...</button>
				   </div>
				{planet.slug !== 'planeta-alquezar' && (
					<p>
						Este mini planeta surge de una captura 360° reinterpretada en formato polar. Su
			 			composición resalta el equilibrio entre terreno y ritmo visual, creando una
						lectura inmersiva en un solo vistazo.
					</p>
				)}
				<div class="meta">
					   <div>
						   <span>Nombre científico</span>
						   <strong>{planet.nombreCientifico}</strong>
					   </div>
				</div>
				<div class="sheet">
						<p><strong>Ubicación original:</strong> {planet.location}</p>
						<p><strong>Coordenadas:</strong> {planet.coordinates}</p>
						<p><strong>Fecha de descubrimiento:</strong> {discoveryDate}</p>
						<p><strong>Equipo técnico:</strong> {planet.equipment}</p>
				</div>
				<div class="actions-primary actions-primary-inline">
					<button type="button" class="highlight action-card" data-open-fullscreen title="Click para ver el planeta a pantalla completa">
						<img src={fullScreenIcon} alt="" class="action-icon" aria-hidden="true" />
						<span>Pantalla completa</span>
					</button>
					       {hasEquirectangularImage && sphericalPublicPath ? (
						       <a class="highlight action-card" href={toBasePath(`planetas/${planet.slug}/aterrizar/?img=${encodeURIComponent(sphericalPublicPath)}`)} title="Click para aterrizar en este planeta">
							       <img src={landingIcon} alt="" class="action-icon" aria-hidden="true" />
							       <span>Aterrizar</span>
						       </a>
					       ) : (
						       <span class="highlight action-card action-card-disabled" title="No hay imagen 360 disponible">
							       <img src={landingIcon} alt="" class="action-icon" aria-hidden="true" />
							       <span>Aterrizar</span>
						       </span>
					       )}
					<button type="button" class="highlight action-card" data-share-planet title="Click para compartir este planeta">
						<img src={shareIcon} alt="" class="action-icon" aria-hidden="true" />
						<span>Compartir</span>
					</button>
				</div>
					       <style>
					       .action-card-disabled {
						       opacity: 0.55;
						       pointer-events: none;
						       cursor: not-allowed;
							   filter: grayscale(0.85) blur(2.5px) brightness(0.92);
						       background: linear-gradient(120deg, rgba(120,120,120,0.13), rgba(44,44,44,0.18));
						       box-shadow: 0 2px 12px 0 rgba(0,0,0,0.10);
						       transition: filter 0.18s, opacity 0.18s;
					       }
					       .action-card-disabled .action-icon {
							   filter: grayscale(1) blur(1.2px) brightness(0.85);
						       opacity: 0.7;
					       }
					       .action-card-disabled span {
						       color: var(--muted);
						       text-shadow: 0 1px 2px rgba(0,0,0,0.13);
					       }
					       </style>
				       <div class="actions-secondary">
					<a class="solid" href={toBasePath('catalogo')}>Volver al catálogo</a>
					<a class="ghost" href={toBasePath('')}>Ver muro universo</a>
				</div>
			</section>
		</main>
		<footer class="footer">
			<p>© 2026 MINIPLANETAS .:. SQLP .:. Made with ❤️ in Tierz for the entire Universe...</p>
		</footer>

		<div class="viewer" data-viewer aria-hidden="true">
			<div class="viewer-controls">
				<button class="viewer-control" type="button" aria-label="Reducir" title="Reducir" data-zoom-out>-</button>
				<button class="viewer-control" type="button" aria-label="Restaurar" title="Restaurar" data-zoom-reset><span aria-hidden="true">↺</span></button>
				<button class="viewer-control" type="button" aria-label="Ampliar" title="Ampliar" data-zoom-in>+</button>
				<button class="viewer-control viewer-close" type="button" aria-label="Cerrar visor" title="Cerrar" data-close-viewer>x</button>
			</div>
			<div class="viewer-stage" data-viewer-stage>
				<img src={viewerImagePath} alt={`Imagen completa de ${planet.name}`} data-viewer-image draggable="false" />
			</div>
		</div>

		<script is:inline>
			const topHeader = document.querySelector('.top');
			const menuToggle = topHeader?.querySelector('.menu-toggle');
			const topNav = topHeader?.querySelector('.top-nav');

			if (topHeader && menuToggle && topNav) {
				topHeader.classList.add('is-menu-ready');

				const closeMenu = () => {
					topNav.classList.remove('is-open');
					menuToggle.setAttribute('aria-expanded', 'false');
					menuToggle.setAttribute('aria-label', 'Abrir menú');
				};

				menuToggle.addEventListener('click', () => {
					const isOpen = menuToggle.getAttribute('aria-expanded') === 'true';
					const shouldOpen = !isOpen;
					topNav.classList.toggle('is-open', shouldOpen);
					menuToggle.setAttribute('aria-expanded', String(shouldOpen));
					menuToggle.setAttribute('aria-label', shouldOpen ? 'Cerrar menú' : 'Abrir menú');
				});

				topNav.querySelectorAll('a').forEach((link) => {
					link.addEventListener('click', closeMenu);
				});

				window.addEventListener('resize', () => {
					if (window.innerWidth > 900) {
						closeMenu();
					}
				});
			}

			const planetView = document.querySelector('.planet-view');
			const likesApiUrl = planetView?.getAttribute('data-likes-api-url')?.trim() || '';
			const currentPlanetSlug = planetView?.getAttribute('data-planet-slug')?.trim() || '';
			const fullButton = document.querySelector('[data-open-fullscreen]');
			const shareButton = document.querySelector('[data-share-planet]');
			const likeButton = document.querySelector('[data-like-planet]');
			const descriptionEl = document.querySelector('[data-description]');
			const descriptionToggle = document.querySelector('[data-toggle-description]');
			const mainImage = document.querySelector('[data-main-image]');
			const viewer = document.querySelector('[data-viewer]');
			const viewerStage = document.querySelector('[data-viewer-stage]');
			const viewerImage = document.querySelector('[data-viewer-image]');
			const closeViewerButton = document.querySelector('[data-close-viewer]');
			const zoomInButton = document.querySelector('[data-zoom-in]');
			const zoomOutButton = document.querySelector('[data-zoom-out]');
			const zoomResetButton = document.querySelector('[data-zoom-reset]');

			const BASE_MIN_ZOOM = 0.02;
			const BASE_MAX_ZOOM = 1;
			const ZOOM_STEP = 0.2;
			let zoomLevel = 1;
			let minZoom = BASE_MIN_ZOOM;
			let maxZoom = BASE_MAX_ZOOM;

			const getImageNaturalWidth = () => {
				if (viewerImage?.naturalWidth) {
					return viewerImage.naturalWidth;
				}
				if (mainImage?.naturalWidth) {
					return mainImage.naturalWidth;
				}
				return 0;
			};

			const getFitToWidthZoom = () => {
				if (!viewerStage) {
					return 1;
				}

				const naturalWidth = getImageNaturalWidth();
				if (!naturalWidth) {
					return 1;
				}

				const targetWidth = viewerStage.clientWidth;
				return targetWidth / naturalWidth;
			};

			const updateZoomBounds = () => {
				const fitToWidthZoom = getFitToWidthZoom();
				minZoom = Math.max(BASE_MIN_ZOOM, fitToWidthZoom || BASE_MIN_ZOOM);
				maxZoom = BASE_MAX_ZOOM;

				// If fitting width requires scaling above original size, collapse bounds safely.
				if (minZoom > maxZoom) {
					minZoom = maxZoom;
				}
			};

			const updateZoomButtons = () => {
				if (zoomInButton) {
					zoomInButton.disabled = zoomLevel >= maxZoom;
				}
				if (zoomOutButton) {
					zoomOutButton.disabled = zoomLevel <= minZoom;
				}
			};

			const updateViewerImageVerticalCenter = () => {
				if (!viewerImage || !viewerStage) {
					return;
				}

				const imageHeight = viewerImage.naturalHeight > 0
					? viewerImage.naturalHeight * zoomLevel
					: viewerImage.clientHeight;
				const freeVerticalSpace = Math.max(viewerStage.clientHeight - imageHeight, 0);
				const verticalMargin = freeVerticalSpace / 2;

				viewerImage.style.marginTop = `${verticalMargin}px`;
				viewerImage.style.marginBottom = `${verticalMargin}px`;
			};

			const applyZoom = (nextZoom, preserveCenter = true, focusClientX = null, focusClientY = null) => {
				if (!viewerImage || !viewerStage) {
					return;
				}

				const clamped = Math.min(maxZoom, Math.max(minZoom, nextZoom));
				const previousZoom = zoomLevel;
				if (Math.abs(clamped - previousZoom) < 0.001) {
					updateZoomButtons();
					return;
				}

				let localFocusX = viewerStage.clientWidth / 2;
				let localFocusY = viewerStage.clientHeight / 2;
				if (focusClientX !== null && focusClientY !== null) {
					const stageRect = viewerStage.getBoundingClientRect();
					localFocusX = focusClientX - stageRect.left;
					localFocusY = focusClientY - stageRect.top;
				}

				const previousFocusX = viewerStage.scrollLeft + localFocusX;
				const previousFocusY = viewerStage.scrollTop + localFocusY;

				zoomLevel = clamped;

				const naturalWidth = viewerImage.naturalWidth;
				const naturalHeight = viewerImage.naturalHeight;
				if (naturalWidth > 0 && naturalHeight > 0) {
					viewerImage.style.width = `${naturalWidth * zoomLevel}px`;
					viewerImage.style.height = `${naturalHeight * zoomLevel}px`;
				}

				updateViewerImageVerticalCenter();

				if (preserveCenter && previousZoom > 0) {
					const zoomRatio = zoomLevel / previousZoom;
					viewerStage.scrollLeft = Math.max(previousFocusX * zoomRatio - localFocusX, 0);
					viewerStage.scrollTop = Math.max(previousFocusY * zoomRatio - localFocusY, 0);
				}

				updateZoomButtons();
			};

			const openViewer = () => {
				if (!viewer || !viewerStage || !viewerImage || !mainImage) {
					return;
				}
				viewerImage.setAttribute('src', mainImage.getAttribute('src') || '');
				viewer.classList.add('is-open');
				viewer.setAttribute('aria-hidden', 'false');
				document.body.classList.add('viewer-open');
				updateZoomBounds();
				applyZoom(getFitToWidthZoom(), false);
				requestAnimationFrame(() => {
					viewerStage.scrollLeft = Math.max((viewerStage.scrollWidth - viewerStage.clientWidth) / 2, 0);
					viewerStage.scrollTop = Math.max((viewerStage.scrollHeight - viewerStage.clientHeight) / 2, 0);
				});
			};

			const closeViewer = () => {
				if (!viewer) {
					return;
				}
				viewer.classList.remove('is-open');
				viewer.setAttribute('aria-hidden', 'true');
				document.body.classList.remove('viewer-open');
			};

			const sharePlanet = async () => {
				const shareUrl = window.location.href;
				const shareTitle = document.title;
				const shareText = `Descubre ${shareTitle}`;

				const tryShareWithImage = async () => {
					const imageUrl = mainImage?.getAttribute('data-share-src') || mainImage?.getAttribute('src');
					if (!imageUrl || !navigator.canShare) {
						return false;
					}

					try {
						const response = await fetch(imageUrl);
						if (!response.ok) {
							return false;
						}

						const blob = await response.blob();
						const fileType = blob.type || 'image/jpeg';
						const extension = (fileType.split('/')[1] || 'jpg').split(';')[0];
						const safeTitle = shareTitle
							.toLowerCase()
							.replace(/[^a-z0-9]+/g, '-')
							.replace(/^-+|-+$/g, '') || 'miniplaneta';
						const imageFile = new File([blob], `${safeTitle}.${extension}`, {
							type: fileType,
						});

						if (!navigator.canShare({ files: [imageFile] })) {
							return false;
						}

						await navigator.share({
							title: shareTitle,
							text: shareText,
							url: shareUrl,
							files: [imageFile],
						});

						return true;
					} catch {
						return false;
					}
				};

				if (navigator.share) {
					try {
						const sharedWithImage = await tryShareWithImage();
						if (sharedWithImage) {
							return;
						}

						await navigator.share({
							title: shareTitle,
							text: shareText,
							url: shareUrl,
						});
						return;
					} catch (error) {
						if (error && error.name === 'AbortError') {
							return;
						}
					}
				}

				try {
					await navigator.clipboard.writeText(shareUrl);
					alert('Enlace copiado al portapapeles');
				} catch {
					const tempInput = document.createElement('input');
					tempInput.value = shareUrl;
					document.body.appendChild(tempInput);
					tempInput.select();
					document.execCommand('copy');
					document.body.removeChild(tempInput);
					alert('Enlace copiado al portapapeles');
				}
			};

			const likeStorageScope = currentPlanetSlug || window.location.pathname;
			const LIKE_STORAGE_KEY = `planet-like:${likeStorageScope}`;
			const LIKE_COUNT_STORAGE_KEY = `planet-like-count:${likeStorageScope}`;
			const LIKE_VISITOR_ID_STORAGE_KEY = 'planet-like-visitor-id';
			const LIKE_REQUEST_TIMEOUT_MS = 6000;
			const LIKE_SYNC_INTERVAL_MS = 15000;
			let likeRequestPending = false;

			const getLikedState = () => {
				try {
					return window.localStorage.getItem(LIKE_STORAGE_KEY) === 'true';
				} catch {
					return false;
				}
			};

			const getLikeCount = () => {
				try {
					const stored = Number.parseInt(window.localStorage.getItem(LIKE_COUNT_STORAGE_KEY) || '0', 10);
					return Number.isFinite(stored) && stored > 0 ? stored : 0;
				} catch {
					return 0;
				}
			};

			const getVisitorId = () => {
				try {
					const stored = window.localStorage.getItem(LIKE_VISITOR_ID_STORAGE_KEY);
					if (stored) {
						return stored;
					}

					const generated = window.crypto?.randomUUID?.()
						?? `visitor-${Math.random().toString(36).slice(2)}-${Date.now()}`;
					window.localStorage.setItem(LIKE_VISITOR_ID_STORAGE_KEY, generated);
					return generated;
				} catch {
					return 'anonymous-visitor';
				}
			};

			const setLikedState = (liked) => {
				try {
					window.localStorage.setItem(LIKE_STORAGE_KEY, String(liked));
				} catch {
					// Ignorar si el navegador bloquea el almacenamiento.
				}
			};

			const setLikeCount = (count) => {
				try {
					window.localStorage.setItem(LIKE_COUNT_STORAGE_KEY, String(Math.max(0, count)));
				} catch {
					// Ignorar si el navegador bloquea el almacenamiento.
				}
			};

			const normalizeLikeCount = (value) => {
				const parsed = Number(value);
				return Number.isFinite(parsed) && parsed > 0 ? Math.floor(parsed) : 0;
			};

			const applyLikeState = (liked, count) => {
				setLikedState(Boolean(liked));
				setLikeCount(normalizeLikeCount(count));
				updateLikeButton();
			};

			const formatLikeCountText = (likeCount) => {
				if (likeCount <= 0) {
					return 'A nadie le gusta ☹️';
				}

				return likeCount === 1
					? 'A 1 persona le gusta'
					: `A ${likeCount} personas les gusta`;
			};

			const updateLikeButton = () => {
				if (!likeButton) {
					return;
				}

				const liked = getLikedState();
				let likeCount = getLikeCount();

				if (liked && likeCount === 0) {
					likeCount = 1;
					setLikeCount(likeCount);
				}

				likeButton.classList.toggle('is-liked', liked);
				likeButton.setAttribute('aria-pressed', String(liked));
				likeButton.setAttribute('title', liked ? 'Te gusta este planeta' : 'Me gusta');
				likeButton.setAttribute('aria-label', liked ? 'Quitar Me gusta de este planeta' : 'Marcar este planeta con Me gusta');
				likeButton.disabled = likeRequestPending;

				const likeLabel = likeButton.querySelector('[data-like-label]');
				if (likeLabel) {
					likeLabel.textContent = liked ? 'Te gusta' : 'Me gusta';
					likeLabel.setAttribute('aria-hidden', 'false');
				}

				const likeCountEl = document.querySelector('[data-like-count]');
				if (likeCountEl) {
					likeCountEl.textContent = formatLikeCountText(likeCount);
				}
			};

			const fetchJsonWithTimeout = async (url, options = {}) => {
				const controller = new AbortController();
				const timeoutId = window.setTimeout(() => controller.abort(), LIKE_REQUEST_TIMEOUT_MS);

				try {
					const response = await fetch(url, {
						...options,
						signal: controller.signal,
					});

					if (!response.ok) {
						throw new Error('Network response was not ok');
					}

					return response.json();
				} finally {
					window.clearTimeout(timeoutId);
				}
			};

			const syncLikeStateFromApi = async () => {
				updateLikeButton();

				if (!likesApiUrl || !currentPlanetSlug || !likeButton) {
					return;
				}

				if (likeRequestPending) {
					return;
				}

				try {
					const requestUrl = new URL(likesApiUrl);
					requestUrl.searchParams.set('slug', currentPlanetSlug);
					requestUrl.searchParams.set('visitorId', getVisitorId());
					requestUrl.searchParams.set('_t', String(Date.now()));

					const payload = await fetchJsonWithTimeout(requestUrl.toString(), {
						method: 'GET',
						cache: 'no-store',
						headers: {
							Accept: 'application/json',
						},
					});
					applyLikeState(Boolean(payload?.liked), payload?.count);
				} catch {
					// Si la API no responde, se mantiene el fallback local.
					updateLikeButton();
				}
			};

			fullButton?.addEventListener('click', openViewer);
			shareButton?.addEventListener('click', sharePlanet);
			likeButton?.addEventListener('click', async () => {
				if (likeRequestPending) {
					return;
				}

				const currentCount = getLikeCount();
				const nextLiked = !getLikedState();
				const nextCount = nextLiked ? Math.max(1, currentCount + 1) : Math.max(0, currentCount - 1);
				applyLikeState(nextLiked, nextCount);
				likeRequestPending = true;
				updateLikeButton();

				try {
					if (likesApiUrl && currentPlanetSlug) {
						const payload = await fetchJsonWithTimeout(likesApiUrl, {
							method: 'POST',
							headers: {
								'Content-Type': 'application/json',
								Accept: 'application/json',
							},
							body: JSON.stringify({
								slug: currentPlanetSlug,
								visitorId: getVisitorId(),
								liked: nextLiked,
							}),
						});
						applyLikeState(Boolean(payload?.liked), payload?.count);
						return;
					}
				} catch {
					// Mantener fallback local si la API falla temporalmente.
					applyLikeState(nextLiked, nextCount);
				} finally {
					likeRequestPending = false;
					updateLikeButton();
				}
			});
			void syncLikeStateFromApi();

			let likeSyncIntervalId = null;
			if (likesApiUrl && currentPlanetSlug) {
				likeSyncIntervalId = window.setInterval(() => {
					if (document.visibilityState === 'visible') {
						void syncLikeStateFromApi();
					}
				}, LIKE_SYNC_INTERVAL_MS);

				window.addEventListener('focus', () => {
					void syncLikeStateFromApi();
				});

				window.addEventListener('online', () => {
					void syncLikeStateFromApi();
				});

				document.addEventListener('visibilitychange', () => {
					if (document.visibilityState === 'visible') {
						void syncLikeStateFromApi();
					}
				});

				window.addEventListener('beforeunload', () => {
					if (likeSyncIntervalId !== null) {
						window.clearInterval(likeSyncIntervalId);
					}
				});
			}

			descriptionToggle?.addEventListener('click', () => {
				if (!descriptionEl || !descriptionToggle) {
					return;
				}

				const willExpand = descriptionEl.classList.contains('is-collapsed');
				descriptionEl.classList.toggle('is-collapsed', !willExpand);
				descriptionToggle.textContent = willExpand ? 'Leer menos' : 'Leer más...';
				descriptionToggle.setAttribute('aria-expanded', String(willExpand));
			});
			mainImage?.addEventListener('click', openViewer);
			closeViewerButton?.addEventListener('click', closeViewer);
			zoomInButton?.addEventListener('click', () => applyZoom(zoomLevel + ZOOM_STEP));
			zoomOutButton?.addEventListener('click', () => applyZoom(zoomLevel - ZOOM_STEP));
			zoomResetButton?.addEventListener('click', () => {
				updateZoomBounds();
				applyZoom(getFitToWidthZoom());
			});
			viewerImage?.addEventListener('load', () => {
				updateZoomBounds();
				applyZoom(zoomLevel, false);
			});

			window.addEventListener('resize', () => {
				if (!viewer?.classList.contains('is-open')) {
					return;
				}

				updateZoomBounds();
				applyZoom(zoomLevel, false);
			});
			viewer?.addEventListener('click', (event) => {
				if (event.target === viewer) {
					closeViewer();
				}
			});

			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') {
					closeViewer();
				}
			});

			if (viewerStage) {
				let isDragging = false;
				let startX = 0;
				let startY = 0;
				let startLeft = 0;
				let startTop = 0;
				let isTouchDragging = false;
				let pinchStartDistance = 0;
				let pinchStartZoom = 1;

				const touchDistance = (firstTouch, secondTouch) => {
					return Math.hypot(secondTouch.clientX - firstTouch.clientX, secondTouch.clientY - firstTouch.clientY);
				};

				const touchCenter = (firstTouch, secondTouch) => {
					return {
						x: (firstTouch.clientX + secondTouch.clientX) / 2,
						y: (firstTouch.clientY + secondTouch.clientY) / 2
					};
				};

				viewerStage.addEventListener('mousedown', (event) => {
					if (!viewer?.classList.contains('is-open')) {
						return;
					}
					isDragging = true;
					startX = event.clientX;
					startY = event.clientY;
					startLeft = viewerStage.scrollLeft;
					startTop = viewerStage.scrollTop;
					viewerStage.classList.add('is-dragging');
					event.preventDefault();
				});

				window.addEventListener('mousemove', (event) => {
					if (!isDragging) {
						return;
					}
					viewerStage.scrollLeft = startLeft - (event.clientX - startX);
					viewerStage.scrollTop = startTop - (event.clientY - startY);
				});

				window.addEventListener('mouseup', () => {
					if (!isDragging) {
						return;
					}
					isDragging = false;
					viewerStage.classList.remove('is-dragging');
				});

				viewerStage.addEventListener('touchstart', (event) => {
					if (!viewer?.classList.contains('is-open')) {
						return;
					}

					if (event.touches.length === 1) {
						const [touch] = event.touches;
						isTouchDragging = true;
						pinchStartDistance = 0;
						startX = touch.clientX;
						startY = touch.clientY;
						startLeft = viewerStage.scrollLeft;
						startTop = viewerStage.scrollTop;
						viewerStage.classList.add('is-dragging');
					}

					if (event.touches.length === 2) {
						const [firstTouch, secondTouch] = event.touches;
						isTouchDragging = false;
						viewerStage.classList.remove('is-dragging');
						pinchStartDistance = touchDistance(firstTouch, secondTouch);
						pinchStartZoom = zoomLevel;
					}
				}, { passive: true });

				viewerStage.addEventListener('touchmove', (event) => {
					if (!viewer?.classList.contains('is-open')) {
						return;
					}

					if (event.touches.length === 1 && isTouchDragging) {
						const [touch] = event.touches;
						viewerStage.scrollLeft = startLeft - (touch.clientX - startX);
						viewerStage.scrollTop = startTop - (touch.clientY - startY);
						event.preventDefault();
					}

					if (event.touches.length === 2 && pinchStartDistance > 0) {
						const [firstTouch, secondTouch] = event.touches;
						const currentDistance = touchDistance(firstTouch, secondTouch);
						if (currentDistance > 0) {
							const center = touchCenter(firstTouch, secondTouch);
							const nextZoom = pinchStartZoom * (currentDistance / pinchStartDistance);
							applyZoom(nextZoom, true, center.x, center.y);
						}
						event.preventDefault();
					}
				}, { passive: false });

				const resetTouchInteraction = () => {
					isTouchDragging = false;
					pinchStartDistance = 0;
					viewerStage.classList.remove('is-dragging');
				};

				viewerStage.addEventListener('touchend', (event) => {
					if (event.touches.length === 1) {
						const [touch] = event.touches;
						isTouchDragging = true;
						pinchStartDistance = 0;
						startX = touch.clientX;
						startY = touch.clientY;
						startLeft = viewerStage.scrollLeft;
						startTop = viewerStage.scrollTop;
						viewerStage.classList.add('is-dragging');
						return;
					}

					if (event.touches.length === 0) {
						resetTouchInteraction();
					}
				});

				viewerStage.addEventListener('touchcancel', resetTouchInteraction);
			}


		</script>
	</body>
