---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { planetData } from '../../data/planets';
import logoImage from '../../assets/ui/logoMiniPlanetas.png';

type Planet = {
	slug: string;
	name: string;
	image: string;
	image360?: string;
	description: string;
	tone: string;
	orbit: string;
	size: string;
	location: string;
	coordinates: string;
	atmosphere: string[];
	discoveryDate: string;
	equipment: string;
	sheet: {
		location: string;
		coordinates: string;
		atmosphere: string[];
		discoveryDate: string;
		equipment: string;
		tone: string;
		orbit: string;
		size: string;
	};
};

export function getStaticPaths() {
	return planetData.map((planet) => ({
		params: { slug: planet.slug },
		props: { planet },
	}));
}

const { planet } = Astro.props as { planet: Planet };
const basePath = import.meta.env.BASE_URL;
const normalizedBase =
	basePath === '/' ? '' : `/${basePath.replace(/^\/+|\/+$/g, '')}`;
const toBasePath = (path = '') => `${normalizedBase}/${path.replace(/^\/+/, '')}`;
const toAssetPath = (path = '') =>
	path.startsWith('/') ? `${normalizedBase}${path}` : `${normalizedBase}/${path}`;
const toPublicAssetPath = (path = '') =>
	typeof path === 'string' && normalizedBase && path.startsWith(`${normalizedBase}/`)
		? path.slice(normalizedBase.length)
		: path;
const planetImages = import.meta.glob('../../assets/planets/*.{jpg,jpeg,png,JPG,JPEG,PNG}', {
	eager: true,
	import: 'default',
});
const planetImageFileName = planet.image.split('/').pop() ?? '';
const optimizedPlanetImage = Object.entries(planetImages).find(([filePath]) =>
	filePath.endsWith(`/${planetImageFileName}`)
)?.[1] as ImageMetadata | undefined;
const discoveryDate = new Date(planet.sheet.discoveryDate).toLocaleDateString('es-ES', {
	day: '2-digit',
	month: 'long',
	year: 'numeric',
});
const sphericalImage = planet.image360;
const sphericalPublicPath = sphericalImage ? toPublicAssetPath(sphericalImage) : null;
const hasEquirectangularImage = Boolean(
	sphericalPublicPath?.startsWith('/pano360/')
);
const fullScreenIcon = toBasePath('FullScreen.png');
const landingIcon = toBasePath('Landing.png');
const shareIcon = toBasePath('compartir.png');
const siteUrl = Astro.site ?? new URL('https://albertoepic.github.io');
const planetRelativeUrl = toBasePath(`planetas/${planet.slug}`);
const planetAbsoluteUrl = new URL(planetRelativeUrl, siteUrl).toString();
const shareImagePath = planet.image.replace('/planets/', '/planets-share/');
const shareImageUrl = toAssetPath(shareImagePath);
const shareImageAbsoluteUrl = new URL(shareImageUrl, siteUrl).toString();
const shareDescription =
	planet.description.length > 200
		? `${planet.description.slice(0, 197)}...`
		: planet.description;
const feedbackFormId = import.meta.env.PUBLIC_FORMINIT_FEEDBACK_FORM_ID?.trim() ?? '';
const feedbackAction = feedbackFormId ? `https://forminit.com/f/${feedbackFormId}` : '';
const feedbackTextareaId = `feedback-message-${planet.slug}`;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href={toBasePath('faviconMP.png')} />
		<link rel="shortcut icon" type="image/png" href={toBasePath('faviconMP.png')} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{planet.name} | MINIPLANETAS</title>
		<meta name="description" content={shareDescription} />
		<link rel="canonical" href={planetAbsoluteUrl} />

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="MINIPLANETAS" />
		<meta property="og:title" content={`${planet.name} | MINIPLANETAS`} />
		<meta property="og:description" content={shareDescription} />
		<meta property="og:url" content={planetAbsoluteUrl} />
		<meta property="og:image" content={shareImageAbsoluteUrl} />
		<meta property="og:image:alt" content={`Mini-planeta ${planet.name}`} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={`${planet.name} | MINIPLANETAS`} />
		<meta name="twitter:description" content={shareDescription} />
		<meta name="twitter:image" content={shareImageAbsoluteUrl} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Space+Grotesk:wght@400;500;600&display=swap"
		/>
	</head>
	<body>
		<header class="top">
			<a class="brand" href={toBasePath('')}>
				<Image src={logoImage} alt="" class="brand-logo" aria-hidden="true" loading="eager" />
				<span class="brand-text">MINIPLANETAS</span>
			</a>
			<button class="menu-toggle" type="button" aria-label="Abrir menú" aria-controls="main-nav" aria-expanded="false">
				<span></span>
				<span></span>
				<span></span>
			</button>
			<nav class="top-nav" id="main-nav">
				<a href={toBasePath('')}>El Universo</a>
				<a href={toBasePath('catalogo')} aria-current="page">Catálogo</a>
				<a href={toBasePath('como-nace-un-mini-planeta')}>¿Cómo nace un mini-planeta?</a>
				<a href={toBasePath('sobre-el-creador')}>Sobre el creador</a>
			</nav>
		</header>

		<main class="planet-view">
			<section class="visual">
				{optimizedPlanetImage ? (
					<Image src={optimizedPlanetImage} alt={`Vista grande de ${planet.name}`} loading="eager" data-main-image data-share-src={shareImageUrl} />
				) : (
					<img src={toAssetPath(planet.image)} alt={`Vista grande de ${planet.name}`} loading="eager" data-main-image data-share-src={shareImageUrl} />
				)}
			</section>

			<section class="story">
				<p class="eyebrow">Ficha del Planeta</p>
				<h1>{planet.name}</h1>
				<div class="lead-wrap">
					<p class="lead is-collapsed" data-description id="planet-description-text">{planet.description}</p>
					<button type="button" class="lead-toggle" data-toggle-description aria-controls="planet-description-text" aria-expanded="false">Leer más...</button>
				</div>
				{planet.slug !== 'planeta-alquezar' && (
					<p>
						Este mini planeta surge de una captura 360° reinterpretada en formato polar. Su
						composición resalta el equilibrio entre terreno, atmósfera y ritmo visual, creando una
						lectura inmersiva en un solo vistazo.
					</p>
				)}
				<div class="sheet">
					<p><strong>Ubicación original:</strong> {planet.sheet.location}</p>
					<p><strong>Coordenadas:</strong> {planet.sheet.coordinates}</p>
					<div class="atmosphere">
						<strong>Atmósfera:</strong>
						<ul>
							{planet.sheet.atmosphere.map((tag: string) => <li>{tag}</li>)}
						</ul>
					</div>
					<p><strong>Fecha de descubrimiento:</strong> {discoveryDate}</p>
					<p><strong>Equipo técnico:</strong> {planet.sheet.equipment}</p>
				</div>
				<div class="meta">
					<div>
						<span>Tono</span>
						<strong>{planet.sheet.tone}</strong>
					</div>
					<div>
						<span>Órbita</span>
						<strong>{planet.sheet.orbit}</strong>
					</div>
					<div>
						<span>Escala</span>
						<strong>{planet.sheet.size}</strong>
					</div>
				</div>
				<div class="actions-primary actions-primary-inline">
					<button type="button" class="highlight action-card" data-open-fullscreen title="Click para ver el planeta a pantalla completa">
						<img src={fullScreenIcon} alt="" class="action-icon" aria-hidden="true" />
						<span>Pantalla completa</span>
					</button>
					{hasEquirectangularImage && sphericalPublicPath ? (
						<a class="highlight action-card" href={toBasePath(`planetas/${planet.slug}/aterrizar?img=${encodeURIComponent(sphericalPublicPath)}`)} title="Click para aterrizar en este planeta">
							<img src={landingIcon} alt="" class="action-icon" aria-hidden="true" />
							<span>Aterrizar</span>
						</a>
					) : (
						<button type="button" class="highlight action-card" disabled aria-disabled="true" title="Click para aterrizar en este planeta">
							<img src={landingIcon} alt="" class="action-icon" aria-hidden="true" />
							<span>Aterrizar</span>
						</button>
					)}
					<button type="button" class="highlight action-card" data-share-planet title="Click para compartir este planeta">
						<img src={shareIcon} alt="" class="action-icon" aria-hidden="true" />
						<span>Compartir</span>
					</button>
				</div>
				<div class="actions-secondary">
					<a class="solid" href={toBasePath('catalogo')}>Volver al catálogo</a>
					<a class="ghost" href={toBasePath('')}>Ver muro universo</a>
				</div>
			</section>
		</main>
		<footer class="footer">
			<p>© 2026 MINIPLANETAS .:. SQLP .:. Made with ❤️ in Tierz for the entire Universe...</p>
		</footer>

		<div class="feedback-popup" data-feedback-popup hidden aria-hidden="true">
			<section class="feedback-widget" data-feedback-widget aria-label="Feedback de la ficha">
				<div class="feedback-head">
					<p class="feedback-question"><strong>¿Te gusta este MINIPLANETA?</strong></p>
					<button type="button" class="feedback-close" data-feedback-close aria-label="Cerrar popup de feedback">×</button>
				</div>
				{feedbackAction ? (
					<>
						<form class="feedback-form" data-feedback-form action={feedbackAction} method="POST">
							<input type="hidden" name="fi-select-pageUrl" data-feedback-page-url value="" />
							<input type="hidden" name="fi-select-helpful" data-feedback-helpful value="" />
							<div class="feedback-buttons" data-feedback-buttons>
								<button type="button" class="feedback-btn feedback-btn-positive" data-feedback-value="yes">
									<span class="feedback-icon" aria-hidden="true">
										<svg class="feedback-icon-svg" viewBox="0 0 24 24" focusable="false" aria-hidden="true">
											<path d="M9 11V20" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2"/>
											<path d="M14.45 4.5c.55.09.95.58.95 1.13v2.74h4.18c1.38 0 2.37 1.33 1.97 2.65l-1.47 4.87a2.7 2.7 0 0 1-2.59 1.92H9V10.7l2.8-2.26 1.1-2.7c.21-.75.83-1.34 1.55-1.24Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2"/>
											<path d="M6.05 10.2H9v9.6H6.05A1.25 1.25 0 0 1 4.8 18.55v-7.1c0-.69.56-1.25 1.25-1.25Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2"/>
										</svg>
									</span>
									<span class="feedback-btn-label">Sí</span>
								</button>
								<button type="button" class="feedback-btn feedback-btn-negative" data-feedback-value="no">
									<span class="feedback-icon feedback-icon-negative" aria-hidden="true">
										<svg class="feedback-icon-svg" viewBox="0 0 24 24" focusable="false" aria-hidden="true">
											<path d="M9 4V13" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2"/>
											<path d="M14.45 19.5c.55-.09.95-.58.95-1.13v-2.74h4.18c1.38 0 2.37-1.33 1.97-2.65l-1.47-4.87a2.7 2.7 0 0 0-2.59-1.92H9v7.11l2.8 2.26 1.1 2.7c.21.75.83 1.34 1.55 1.24Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2"/>
											<path d="M6.05 4.2H9v9.6H6.05A1.25 1.25 0 0 1 4.8 12.55v-7.1c0-.69.56-1.25 1.25-1.25Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2"/>
										</svg>
									</span>
									<span class="feedback-btn-label">No</span>
								</button>
							</div>
							<div class="feedback-details" data-feedback-details hidden>
								<label for={feedbackTextareaId}>¿Qué mejorarías en esta ficha?</label>
								<textarea
									name="fi-text-feedback"
									id={feedbackTextareaId}
									rows="3"
									placeholder="Informacion que falta, detalles poco claros, ideas de mejora..."
								></textarea>
								<button type="submit" class="feedback-submit">Enviar feedback</button>
							</div>
							<p class="feedback-error" data-feedback-error hidden>
								No se pudo enviar el feedback. Intentalo de nuevo en unos segundos.
							</p>
						</form>
						<div class="feedback-thanks" data-feedback-thanks hidden>
							<p>Gracias por tu feedback.</p>
						</div>
					</>
				) : (
					<p class="feedback-warning">
						Define PUBLIC_FORMINIT_FEEDBACK_FORM_ID para activar este widget.
					</p>
				)}
			</section>
		</div>

		<div class="viewer" data-viewer aria-hidden="true">
			<div class="viewer-controls">
				<button class="viewer-control" type="button" aria-label="Reducir" title="Reducir" data-zoom-out>-</button>
				<button class="viewer-control" type="button" aria-label="Restaurar" title="Restaurar" data-zoom-reset><span aria-hidden="true">↺</span></button>
				<button class="viewer-control" type="button" aria-label="Ampliar" title="Ampliar" data-zoom-in>+</button>
				<button class="viewer-control viewer-close" type="button" aria-label="Cerrar visor" title="Cerrar" data-close-viewer>x</button>
			</div>
			<div class="viewer-stage" data-viewer-stage>
				{optimizedPlanetImage ? (
					<Image src={optimizedPlanetImage} alt={`Imagen completa de ${planet.name}`} data-viewer-image draggable="false" />
				) : (
					<img src={toAssetPath(planet.image)} alt={`Imagen completa de ${planet.name}`} data-viewer-image draggable="false" />
				)}
			</div>
		</div>

		<script is:inline>
			const topHeader = document.querySelector('.top');
			const menuToggle = topHeader?.querySelector('.menu-toggle');
			const topNav = topHeader?.querySelector('.top-nav');

			if (topHeader && menuToggle && topNav) {
				topHeader.classList.add('is-menu-ready');

				const closeMenu = () => {
					topNav.classList.remove('is-open');
					menuToggle.setAttribute('aria-expanded', 'false');
					menuToggle.setAttribute('aria-label', 'Abrir menú');
				};

				menuToggle.addEventListener('click', () => {
					const isOpen = menuToggle.getAttribute('aria-expanded') === 'true';
					const shouldOpen = !isOpen;
					topNav.classList.toggle('is-open', shouldOpen);
					menuToggle.setAttribute('aria-expanded', String(shouldOpen));
					menuToggle.setAttribute('aria-label', shouldOpen ? 'Cerrar menú' : 'Abrir menú');
				});

				topNav.querySelectorAll('a').forEach((link) => {
					link.addEventListener('click', closeMenu);
				});

				window.addEventListener('resize', () => {
					if (window.innerWidth > 900) {
						closeMenu();
					}
				});
			}

			const fullButton = document.querySelector('[data-open-fullscreen]');
			const shareButton = document.querySelector('[data-share-planet]');
			const descriptionEl = document.querySelector('[data-description]');
			const descriptionToggle = document.querySelector('[data-toggle-description]');
			const mainImage = document.querySelector('[data-main-image]');
			const viewer = document.querySelector('[data-viewer]');
			const viewerStage = document.querySelector('[data-viewer-stage]');
			const viewerImage = document.querySelector('[data-viewer-image]');
			const closeViewerButton = document.querySelector('[data-close-viewer]');
			const zoomInButton = document.querySelector('[data-zoom-in]');
			const zoomOutButton = document.querySelector('[data-zoom-out]');
			const zoomResetButton = document.querySelector('[data-zoom-reset]');

			const BASE_MIN_ZOOM = 0.02;
			const BASE_MAX_ZOOM = 1;
			const ZOOM_STEP = 0.2;
			let zoomLevel = 1;
			let minZoom = BASE_MIN_ZOOM;
			let maxZoom = BASE_MAX_ZOOM;

			const getImageNaturalWidth = () => {
				if (viewerImage?.naturalWidth) {
					return viewerImage.naturalWidth;
				}
				if (mainImage?.naturalWidth) {
					return mainImage.naturalWidth;
				}
				return 0;
			};

			const getFitToWidthZoom = () => {
				if (!viewerStage) {
					return 1;
				}

				const naturalWidth = getImageNaturalWidth();
				if (!naturalWidth) {
					return 1;
				}

				const targetWidth = viewerStage.clientWidth;
				return targetWidth / naturalWidth;
			};

			const updateZoomBounds = () => {
				const fitToWidthZoom = getFitToWidthZoom();
				minZoom = Math.max(BASE_MIN_ZOOM, fitToWidthZoom || BASE_MIN_ZOOM);
				maxZoom = BASE_MAX_ZOOM;

				// If fitting width requires scaling above original size, collapse bounds safely.
				if (minZoom > maxZoom) {
					minZoom = maxZoom;
				}
			};

			const updateZoomButtons = () => {
				if (zoomInButton) {
					zoomInButton.disabled = zoomLevel >= maxZoom;
				}
				if (zoomOutButton) {
					zoomOutButton.disabled = zoomLevel <= minZoom;
				}
			};

			const updateViewerImageVerticalCenter = () => {
				if (!viewerImage || !viewerStage) {
					return;
				}

				const imageHeight = viewerImage.naturalHeight > 0
					? viewerImage.naturalHeight * zoomLevel
					: viewerImage.clientHeight;
				const freeVerticalSpace = Math.max(viewerStage.clientHeight - imageHeight, 0);
				const verticalMargin = freeVerticalSpace / 2;

				viewerImage.style.marginTop = `${verticalMargin}px`;
				viewerImage.style.marginBottom = `${verticalMargin}px`;
			};

			const applyZoom = (nextZoom, preserveCenter = true, focusClientX = null, focusClientY = null) => {
				if (!viewerImage || !viewerStage) {
					return;
				}

				const clamped = Math.min(maxZoom, Math.max(minZoom, nextZoom));
				const previousZoom = zoomLevel;
				if (Math.abs(clamped - previousZoom) < 0.001) {
					updateZoomButtons();
					return;
				}

				let localFocusX = viewerStage.clientWidth / 2;
				let localFocusY = viewerStage.clientHeight / 2;
				if (focusClientX !== null && focusClientY !== null) {
					const stageRect = viewerStage.getBoundingClientRect();
					localFocusX = focusClientX - stageRect.left;
					localFocusY = focusClientY - stageRect.top;
				}

				const previousFocusX = viewerStage.scrollLeft + localFocusX;
				const previousFocusY = viewerStage.scrollTop + localFocusY;

				zoomLevel = clamped;

				const naturalWidth = viewerImage.naturalWidth;
				const naturalHeight = viewerImage.naturalHeight;
				if (naturalWidth > 0 && naturalHeight > 0) {
					viewerImage.style.width = `${naturalWidth * zoomLevel}px`;
					viewerImage.style.height = `${naturalHeight * zoomLevel}px`;
				}

				updateViewerImageVerticalCenter();

				if (preserveCenter && previousZoom > 0) {
					const zoomRatio = zoomLevel / previousZoom;
					viewerStage.scrollLeft = Math.max(previousFocusX * zoomRatio - localFocusX, 0);
					viewerStage.scrollTop = Math.max(previousFocusY * zoomRatio - localFocusY, 0);
				}

				updateZoomButtons();
			};

			const openViewer = () => {
				if (!viewer || !viewerStage || !viewerImage || !mainImage) {
					return;
				}
				viewerImage.setAttribute('src', mainImage.getAttribute('src') || '');
				viewer.classList.add('is-open');
				viewer.setAttribute('aria-hidden', 'false');
				document.body.classList.add('viewer-open');
				updateZoomBounds();
				applyZoom(getFitToWidthZoom(), false);
				requestAnimationFrame(() => {
					viewerStage.scrollLeft = Math.max((viewerStage.scrollWidth - viewerStage.clientWidth) / 2, 0);
					viewerStage.scrollTop = Math.max((viewerStage.scrollHeight - viewerStage.clientHeight) / 2, 0);
				});
			};

			const closeViewer = () => {
				if (!viewer) {
					return;
				}
				viewer.classList.remove('is-open');
				viewer.setAttribute('aria-hidden', 'true');
				document.body.classList.remove('viewer-open');
			};

			const sharePlanet = async () => {
				const shareUrl = window.location.href;
				const shareTitle = document.title;
				const shareText = `Descubre ${shareTitle}`;

				const tryShareWithImage = async () => {
					const imageUrl = mainImage?.getAttribute('data-share-src') || mainImage?.getAttribute('src');
					if (!imageUrl || !navigator.canShare) {
						return false;
					}

					try {
						const response = await fetch(imageUrl);
						if (!response.ok) {
							return false;
						}

						const blob = await response.blob();
						const fileType = blob.type || 'image/jpeg';
						const extension = (fileType.split('/')[1] || 'jpg').split(';')[0];
						const safeTitle = shareTitle
							.toLowerCase()
							.replace(/[^a-z0-9]+/g, '-')
							.replace(/^-+|-+$/g, '') || 'miniplaneta';
						const imageFile = new File([blob], `${safeTitle}.${extension}`, {
							type: fileType,
						});

						if (!navigator.canShare({ files: [imageFile] })) {
							return false;
						}

						await navigator.share({
							title: shareTitle,
							text: shareText,
							url: shareUrl,
							files: [imageFile],
						});

						return true;
					} catch {
						return false;
					}
				};

				if (navigator.share) {
					try {
						const sharedWithImage = await tryShareWithImage();
						if (sharedWithImage) {
							return;
						}

						await navigator.share({
							title: shareTitle,
							text: shareText,
							url: shareUrl,
						});
						return;
					} catch (error) {
						if (error && error.name === 'AbortError') {
							return;
						}
					}
				}

				try {
					await navigator.clipboard.writeText(shareUrl);
					alert('Enlace copiado al portapapeles');
				} catch {
					const tempInput = document.createElement('input');
					tempInput.value = shareUrl;
					document.body.appendChild(tempInput);
					tempInput.select();
					document.execCommand('copy');
					document.body.removeChild(tempInput);
					alert('Enlace copiado al portapapeles');
				}
			};

			fullButton?.addEventListener('click', openViewer);
			shareButton?.addEventListener('click', sharePlanet);
			descriptionToggle?.addEventListener('click', () => {
				if (!descriptionEl || !descriptionToggle) {
					return;
				}

				const willExpand = descriptionEl.classList.contains('is-collapsed');
				descriptionEl.classList.toggle('is-collapsed', !willExpand);
				descriptionToggle.textContent = willExpand ? 'Leer menos' : 'Leer más...';
				descriptionToggle.setAttribute('aria-expanded', String(willExpand));
			});
			mainImage?.addEventListener('click', openViewer);
			closeViewerButton?.addEventListener('click', closeViewer);
			zoomInButton?.addEventListener('click', () => applyZoom(zoomLevel + ZOOM_STEP));
			zoomOutButton?.addEventListener('click', () => applyZoom(zoomLevel - ZOOM_STEP));
			zoomResetButton?.addEventListener('click', () => {
				updateZoomBounds();
				applyZoom(getFitToWidthZoom());
			});
			viewerImage?.addEventListener('load', () => {
				updateZoomBounds();
				applyZoom(zoomLevel, false);
			});

			window.addEventListener('resize', () => {
				if (!viewer?.classList.contains('is-open')) {
					return;
				}

				updateZoomBounds();
				applyZoom(zoomLevel, false);
			});
			viewer?.addEventListener('click', (event) => {
				if (event.target === viewer) {
					closeViewer();
				}
			});

			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') {
					closeViewer();
				}
			});

			if (viewerStage) {
				let isDragging = false;
				let startX = 0;
				let startY = 0;
				let startLeft = 0;
				let startTop = 0;
				let isTouchDragging = false;
				let pinchStartDistance = 0;
				let pinchStartZoom = 1;

				const touchDistance = (firstTouch, secondTouch) => {
					return Math.hypot(secondTouch.clientX - firstTouch.clientX, secondTouch.clientY - firstTouch.clientY);
				};

				const touchCenter = (firstTouch, secondTouch) => {
					return {
						x: (firstTouch.clientX + secondTouch.clientX) / 2,
						y: (firstTouch.clientY + secondTouch.clientY) / 2
					};
				};

				viewerStage.addEventListener('mousedown', (event) => {
					if (!viewer?.classList.contains('is-open')) {
						return;
					}
					isDragging = true;
					startX = event.clientX;
					startY = event.clientY;
					startLeft = viewerStage.scrollLeft;
					startTop = viewerStage.scrollTop;
					viewerStage.classList.add('is-dragging');
					event.preventDefault();
				});

				window.addEventListener('mousemove', (event) => {
					if (!isDragging) {
						return;
					}
					viewerStage.scrollLeft = startLeft - (event.clientX - startX);
					viewerStage.scrollTop = startTop - (event.clientY - startY);
				});

				window.addEventListener('mouseup', () => {
					if (!isDragging) {
						return;
					}
					isDragging = false;
					viewerStage.classList.remove('is-dragging');
				});

				viewerStage.addEventListener('touchstart', (event) => {
					if (!viewer?.classList.contains('is-open')) {
						return;
					}

					if (event.touches.length === 1) {
						const [touch] = event.touches;
						isTouchDragging = true;
						pinchStartDistance = 0;
						startX = touch.clientX;
						startY = touch.clientY;
						startLeft = viewerStage.scrollLeft;
						startTop = viewerStage.scrollTop;
						viewerStage.classList.add('is-dragging');
					}

					if (event.touches.length === 2) {
						const [firstTouch, secondTouch] = event.touches;
						isTouchDragging = false;
						viewerStage.classList.remove('is-dragging');
						pinchStartDistance = touchDistance(firstTouch, secondTouch);
						pinchStartZoom = zoomLevel;
					}
				}, { passive: true });

				viewerStage.addEventListener('touchmove', (event) => {
					if (!viewer?.classList.contains('is-open')) {
						return;
					}

					if (event.touches.length === 1 && isTouchDragging) {
						const [touch] = event.touches;
						viewerStage.scrollLeft = startLeft - (touch.clientX - startX);
						viewerStage.scrollTop = startTop - (touch.clientY - startY);
						event.preventDefault();
					}

					if (event.touches.length === 2 && pinchStartDistance > 0) {
						const [firstTouch, secondTouch] = event.touches;
						const currentDistance = touchDistance(firstTouch, secondTouch);
						if (currentDistance > 0) {
							const center = touchCenter(firstTouch, secondTouch);
							const nextZoom = pinchStartZoom * (currentDistance / pinchStartDistance);
							applyZoom(nextZoom, true, center.x, center.y);
						}
						event.preventDefault();
					}
				}, { passive: false });

				const resetTouchInteraction = () => {
					isTouchDragging = false;
					pinchStartDistance = 0;
					viewerStage.classList.remove('is-dragging');
				};

				viewerStage.addEventListener('touchend', (event) => {
					if (event.touches.length === 1) {
						const [touch] = event.touches;
						isTouchDragging = true;
						pinchStartDistance = 0;
						startX = touch.clientX;
						startY = touch.clientY;
						startLeft = viewerStage.scrollLeft;
						startTop = viewerStage.scrollTop;
						viewerStage.classList.add('is-dragging');
						return;
					}

					if (event.touches.length === 0) {
						resetTouchInteraction();
					}
				});

				viewerStage.addEventListener('touchcancel', resetTouchInteraction);
			}

			const feedbackPopup = document.querySelector('[data-feedback-popup]');
			const feedbackWidget = feedbackPopup?.querySelector('[data-feedback-widget]');
			const feedbackForm = feedbackPopup?.querySelector('[data-feedback-form]');
			const feedbackClose = feedbackPopup?.querySelector('[data-feedback-close]');
			const footer = document.querySelector('.footer');

			if (feedbackPopup && feedbackWidget && feedbackForm && footer) {
				const STORAGE_VERSION = 'v2';
				const STORAGE_KEY = `fi-feedback-submitted-${STORAGE_VERSION}`;
				const DISMISSED_KEY = `fi-feedback-dismissed-${STORAGE_VERSION}`;
				const DISMISS_TTL_DAYS = 7;
				const DAY_MS = 24 * 60 * 60 * 1000;
				const now = Date.now();
				const pageUrl = window.location.pathname;
				const submittedStored = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
				const dismissedStored = JSON.parse(localStorage.getItem(DISMISSED_KEY) || '{}');
				const submittedPages = Array.isArray(submittedStored) ? submittedStored : [];
				let dismissedByPage = {};

				if (Array.isArray(dismissedStored)) {
					dismissedByPage = Object.fromEntries(
						dismissedStored.map((url) => [url, now])
					);
				} else if (dismissedStored && typeof dismissedStored === 'object') {
					dismissedByPage = dismissedStored;
				}

				Object.keys(dismissedByPage).forEach((url) => {
					const timestamp = Number(dismissedByPage[url]);
					const isExpired = !Number.isFinite(timestamp) || now - timestamp > DISMISS_TTL_DAYS * DAY_MS;
					if (isExpired) {
						delete dismissedByPage[url];
					}
				});
				localStorage.setItem(DISMISSED_KEY, JSON.stringify(dismissedByPage));

				const pageUrlInput = feedbackForm.querySelector('[data-feedback-page-url]');
				const helpfulInput = feedbackForm.querySelector('[data-feedback-helpful]');
				const detailsSection = feedbackForm.querySelector('[data-feedback-details]');
				const thanksMessage = feedbackWidget.querySelector('[data-feedback-thanks]');
				const errorMessage = feedbackForm.querySelector('[data-feedback-error]');
				const buttons = feedbackForm.querySelectorAll('[data-feedback-value]');
				const submitButton = feedbackForm.querySelector('.feedback-submit');

				const showPopup = () => {
					if (feedbackPopup.hidden) {
						feedbackPopup.hidden = false;
						feedbackPopup.setAttribute('aria-hidden', 'false');
						requestAnimationFrame(() => {
							feedbackPopup.classList.add('is-visible');
						});
					}
				};

				const hidePopup = () => {
					feedbackPopup.classList.remove('is-visible');
					feedbackPopup.setAttribute('aria-hidden', 'true');
					setTimeout(() => {
						if (feedbackPopup.getAttribute('aria-hidden') === 'true') {
							feedbackPopup.hidden = true;
						}
					}, 220);
				};

				const shouldSkipPopup = submittedPages.includes(pageUrl) || Boolean(dismissedByPage[pageUrl]);

				if (pageUrlInput && helpfulInput && thanksMessage && buttons.length > 0) {
					pageUrlInput.value = pageUrl;
					if (detailsSection) {
						detailsSection.setAttribute('hidden', '');
						detailsSection.classList.remove('is-visible');
					}
					feedbackClose?.addEventListener('click', () => {
						if (detailsSection) {
							detailsSection.setAttribute('hidden', '');
							detailsSection.classList.remove('is-visible');
						}
						dismissedByPage[pageUrl] = Date.now();
						localStorage.setItem(DISMISSED_KEY, JSON.stringify(dismissedByPage));
						hidePopup();
					});

					if (!shouldSkipPopup) {
						const footerObserver = new IntersectionObserver((entries, observer) => {
							const reachedFooter = entries.some((entry) => entry.isIntersecting);
							if (!reachedFooter) {
								return;
							}

							showPopup();
							observer.disconnect();
						}, {
							threshold: 0.08,
							rootMargin: '0px 0px -20px 0px',
						});

						footerObserver.observe(footer);
					}

					const setBusy = (isBusy) => {
						buttons.forEach((button) => {
							button.disabled = isBusy;
						});
						if (submitButton) {
							submitButton.disabled = isBusy;
						}
					};

					const submitFeedback = async () => {
						errorMessage?.setAttribute('hidden', '');
						setBusy(true);

						try {
							const response = await fetch(feedbackForm.action, {
								method: 'POST',
								body: new FormData(feedbackForm),
								headers: {
									Accept: 'application/json',
								},
							});

							if (!response.ok) {
								throw new Error('Feedback submission failed');
							}

							if (!submittedPages.includes(pageUrl)) {
								submittedPages.push(pageUrl);
								localStorage.setItem(STORAGE_KEY, JSON.stringify(submittedPages));
							}

							if (dismissedByPage[pageUrl]) {
								delete dismissedByPage[pageUrl];
								localStorage.setItem(DISMISSED_KEY, JSON.stringify(dismissedByPage));
							}

							feedbackForm.hidden = true;
							thanksMessage.hidden = false;
							setTimeout(hidePopup, 1400);
						} catch {
							errorMessage?.removeAttribute('hidden');
						} finally {
							setBusy(false);
						}
					};

					buttons.forEach((button) => {
						button.addEventListener('click', async () => {
							buttons.forEach((item) => item.classList.remove('is-selected'));
							button.classList.add('is-selected');
							helpfulInput.value = button.getAttribute('data-feedback-value') || '';

							if (helpfulInput.value === 'no') {
								if (detailsSection) {
									detailsSection.removeAttribute('hidden');
									detailsSection.classList.add('is-visible');
								}
								return;
							}

							if (detailsSection) {
								detailsSection.setAttribute('hidden', '');
								detailsSection.classList.remove('is-visible');
							}
							await submitFeedback();
						});
					});

					feedbackForm.addEventListener('submit', async (event) => {
						event.preventDefault();
						await submitFeedback();
					});
				}
			}

		</script>
	</body>
</html>

